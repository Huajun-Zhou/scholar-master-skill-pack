{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["model_id", "model_name", "description", "source_papers", "reasoning_chain"],
  "properties": {
    "model_id": { "type": "string" },
    "model_name": { "type": "string" },
    "description": { "type": "string" },
    "source_papers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["paper_id", "evidence_id"],
        "properties": {
          "paper_id": { "type": "string" },
          "evidence_id": { "type": "string" },
          "supported_pattern": { "type": "string" }
        }
      }
    },
    "reasoning_chain": {
      "type": "array",
      "items": { "type": "string" }
    },
    "applicable_scenarios": {
      "type": "array",
      "items": { "type": "string" }
    },
    "unsuitable_scenarios": {
      "type": "array",
      "items": { "type": "string" }
    },
    "transfer_template": { "type": "string" },
    "example_transfer": { "type": "string" },
    "evidence_level": {
      "type": "string",
      "enum": ["B", "C"]
    }
  }
}
