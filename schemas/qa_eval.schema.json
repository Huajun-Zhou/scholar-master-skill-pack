{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["test_id", "test_type", "question", "expected_behavior"],
  "properties": {
    "test_id": { "type": "string" },
    "test_type": {
      "type": "string",
      "enum": ["factual", "method", "transfer", "review", "hallucination_pressure"]
    },
    "question": { "type": "string" },
    "expected_behavior": { "type": "string" },
    "min_evidence_count": { "type": "integer" },
    "forbidden_phrases": {
      "type": "array",
      "items": { "type": "string" }
    },
    "required_elements": {
      "type": "array",
      "items": { "type": "string" }
    },
    "scoring": {
      "type": "object",
      "properties": {
        "evidence_coverage": { "type": "number" },
        "hallucination_free": { "type": "boolean" },
        "abc_separation": { "type": "boolean" },
        "usefulness": { "type": "integer", "minimum": 1, "maximum": 5 }
      }
    }
  }
}
